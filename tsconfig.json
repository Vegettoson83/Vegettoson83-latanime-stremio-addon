{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "@cloudflare/workers-types",
      "node"
    ],
    "strict": true,
    "noEmit": false,
    "outDir": "dist",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
