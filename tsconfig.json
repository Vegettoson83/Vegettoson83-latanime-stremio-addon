{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext", "WebWorker"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": false,
    "outDir": "dist",
    "resolveJsonModule": true,
    "allowJs": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*"]
}
